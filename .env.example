# ACTA GHOST configuration. Copy to `.env` and adjust. All values are optional —
# ACTA GHOST runs fully offline with sensible defaults if nothing is set.

# --- Core ---
ACTA_DATA_DIR=.acta
ACTA_LOG_LEVEL=INFO

# --- Security ---
# Base64 Fernet key used to encrypt local data at rest. If unset, ACTA derives
# a key from ACTA_MASTER_PASSWORD, or generates+persists one in ACTA_DATA_DIR.
# ACTA_ENCRYPTION_KEY=
# ACTA_MASTER_PASSWORD=change-me

# --- AI Router / Providers ---
# Default provider when no routing rule matches. One of: mock, openai, anthropic, gemini, ollama
ACTA_DEFAULT_PROVIDER=mock

# OpenAI
# ACTA_OPENAI_API_KEY=sk-...
# ACTA_OPENAI_MODEL=gpt-4o-mini

# Anthropic
# ACTA_ANTHROPIC_API_KEY=sk-ant-...
# ACTA_ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Gemini
# ACTA_GEMINI_API_KEY=...
# ACTA_GEMINI_MODEL=gemini-1.5-flash

# Ollama (local)
# ACTA_OLLAMA_HOST=http://localhost:11434
# ACTA_OLLAMA_MODEL=llama3.1

# --- Localization (RUS / HEB / ENG) ---
# Fallback language when detection is inconclusive: ru | he | en
ACTA_DEFAULT_LANGUAGE=ru

# --- System control (FULL OS ACCESS) ---
# When true, ACTA can run programs, manage processes/services and perform
# unrestricted filesystem operations on this machine. Every action is audited.
# Set to false to disable all system control.
ACTA_ALLOW_SYSTEM_CONTROL=true
ACTA_SYSTEM_EXEC_TIMEOUT=120

# --- Messaging channels ---
# Telegram: create a bot via @BotFather and paste the token. Without a webhook
# URL, ACTA long-polls automatically when the server starts.
# ACTA_TELEGRAM_BOT_TOKEN=123456:ABC...
# ACTA_TELEGRAM_WEBHOOK_URL=https://your.public.host/webhooks/telegram

# WhatsApp (Meta Cloud API): set token + phone number id; configure the webhook
# in the Meta dashboard to POST to /webhooks/whatsapp with this verify token.
# ACTA_WHATSAPP_TOKEN=EAAG...
# ACTA_WHATSAPP_PHONE_ID=1234567890
# ACTA_WHATSAPP_VERIFY_TOKEN=acta-verify

# --- Optional backing stores (MVP works without these) ---
# ACTA_POSTGRES_DSN=postgresql://acta:acta@localhost:5432/acta
# ACTA_NEO4J_URI=bolt://localhost:7687
# ACTA_NEO4J_USER=neo4j
# ACTA_NEO4J_PASSWORD=neo4j
# ACTA_REDIS_URL=redis://localhost:6379/0
