# ACTA GHOST configuration. Copy to `.env` and adjust. All values are optional —
# ACTA GHOST runs fully offline with sensible defaults if nothing is set.
#
# Environment profile:
# - ACTA_ENV=dev  -> permissive local defaults (offline-first).
# - ACTA_ENV=prod -> requires API auth token/users to avoid unauthenticated API binds.

# --- Core ---
ACTA_ENV=dev
ACTA_DATA_DIR=.acta
ACTA_LOG_LEVEL=INFO

# --- Security ---
# Base64 Fernet key used to encrypt local data at rest. If unset, ACTA derives
# a key from ACTA_MASTER_PASSWORD, or generates+persists one in ACTA_DATA_DIR.
# ACTA_ENCRYPTION_KEY=
# ACTA_MASTER_PASSWORD=change-me
# Optional external Fernet key path (SEC-7 hardening).
# ACTA_FERNET_KEY_PATH=/secure/path/fernet.key
# Optional API auth token (Bearer or X-API-Key). If unset, localhost usage
# remains allowed but API/webhooks are unauthenticated.
# ACTA_API_AUTH_TOKEN=change-me
# API hardening defaults (SEC-9)
# ACTA_API_MAX_BODY_SIZE_BYTES=1048576
# ACTA_API_RATE_LIMIT_PER_MINUTE=120
# ACTA_API_CORS_ORIGINS=http://127.0.0.1,http://localhost,http://127.0.0.1:8765,http://localhost:8765

# --- AI Router / Providers ---
# Default provider when no routing rule matches. One of: mock, openai, anthropic, gemini, ollama
ACTA_DEFAULT_PROVIDER=mock

# OpenAI
# ACTA_OPENAI_API_KEY=sk-...
# ACTA_OPENAI_MODEL=gpt-4o-mini

# Anthropic
# ACTA_ANTHROPIC_API_KEY=sk-ant-...
# ACTA_ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Gemini
# ACTA_GEMINI_API_KEY=...
# ACTA_GEMINI_MODEL=gemini-1.5-flash

# Ollama (local)
# ACTA_OLLAMA_HOST=http://localhost:11434
# ACTA_OLLAMA_MODEL=llama3.1

# --- AGENT: Vision-Language Models (VLM) subsystem ---
# Master switch for advanced visual processing (cameras/sensors + VLM). Off by
# default; when enabled it always falls back to a deterministic offline VLM.
ACTA_VISION_ENABLED=false
# Provider strategy: mock | local | cloud | auto (local -> cloud -> mock)
ACTA_VLM_PROVIDER=auto
# Local quantized VLM via Ollama (e.g. llava). Quantization: none | int8 | int4 | fp16
# ACTA_VLM_LOCAL_HOST=http://localhost:11434
# ACTA_VLM_LOCAL_MODEL=llava
# ACTA_VLM_QUANTIZATION=int4
# ACTA_VLM_MAX_TOKENS=256
# Multimodal processor tuning (patch splitting + pixel shuffle).
# ACTA_VISION_PATCH_SIZE=448
# ACTA_VISION_MAX_PATCHES=12
# ACTA_VISION_PIXEL_SHUFFLE_SCALE=0.5
# Visual instruction tuning with LoRA (offline, dependency-free adapter).
# ACTA_VISION_LORA_ENABLED=false
# ACTA_VISION_LORA_RANK=8
# ACTA_VISION_LORA_ALPHA=16

# --- Localization (RUS / HEB / ENG) ---
# Fallback language when detection is inconclusive: ru | he | en
ACTA_DEFAULT_LANGUAGE=ru

# --- System control (FULL OS ACCESS) ---
# When true, ACTA can run programs, manage processes/services and perform
# unrestricted filesystem operations on this machine. Every action is audited.
# Set to false to disable all system control.
ACTA_ALLOW_SYSTEM_CONTROL=false
ACTA_SYSTEM_EXEC_TIMEOUT=120
# Optional sandbox root for destructive fs ops without explicit confirmation.
# ACTA_SYSTEM_FS_ROOT=~/.acta

# --- Messaging channels ---
# Telegram: create a bot via @BotFather and paste the token. Without a webhook
# URL, ACTA long-polls automatically when the server starts.
# ACTA_TELEGRAM_BOT_TOKEN=123456:ABC...
# ACTA_TELEGRAM_WEBHOOK_URL=https://your.public.host/webhooks/telegram
# Comma-separated allowed Telegram chat ids. Empty = allow all senders.
# ACTA_TELEGRAM_ALLOWED_CHAT_IDS=123456,987654

# WhatsApp (Meta Cloud API): set token + phone number id; configure the webhook
# in the Meta dashboard to POST to /webhooks/whatsapp with this verify token.
# ACTA_WHATSAPP_TOKEN=EAAG...
# ACTA_WHATSAPP_PHONE_ID=1234567890
# ACTA_WHATSAPP_VERIFY_TOKEN=acta-verify
# ACTA_WHATSAPP_APP_SECRET=...
# Comma-separated allowed WhatsApp numbers. Empty = allow all senders.
# ACTA_WHATSAPP_ALLOWED_NUMBERS=972500000000,972511111111

# --- Optional backing stores (MVP works without these) ---
# ACTA_POSTGRES_DSN=postgresql://acta:acta@localhost:5432/acta
# ACTA_NEO4J_URI=bolt://localhost:7687
# ACTA_NEO4J_USER=neo4j
# ACTA_NEO4J_PASSWORD=neo4j
# ACTA_REDIS_URL=redis://localhost:6379/0
